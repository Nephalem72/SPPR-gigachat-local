SPPR_DATA_DIR=D:/Notebooks/sppr
SPPR_DATABASE_URL=sqlite:///D:/Notebooks/sppr/sppr_history.db

SPPR_LLM_BACKEND=gigachat
SPPR_LLM_MODEL_ID=GigaChat-2
SPPR_LLM_MAX_NEW_TOKENS=768
SPPR_LLM_MAX_INPUT_TOKENS=6144
